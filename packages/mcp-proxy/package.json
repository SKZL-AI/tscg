{
  "name": "@tscg/mcp-proxy",
  "version": "1.4.2",
  "description": "TSCG MCP Proxy — transparent tool-schema compression for MCP servers. Sits between Claude Code and downstream MCP servers, compressing tool descriptions using TSCG.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tscg-mcp-proxy": "./dist/bin/tscg-mcp-proxy.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "tscg",
    "mcp",
    "model-context-protocol",
    "tool-compression",
    "claude-code",
    "proxy"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin/tscg-mcp-proxy.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "@tscg/core": "^1.4.2"
  },
  "devDependencies": {
    "@tscg/core": "^1.4.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
