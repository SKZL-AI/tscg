{
  "name": "@tscg/tool-optimizer",
  "version": "1.4.3",
  "description": "High-level tool-schema optimizer for LLM agent frameworks. Integrates with LangChain, MCP, Vercel AI SDK.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js",
      "require": "./dist/langchain.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    },
    "./vercel": {
      "types": "./dist/vercel.d.ts",
      "import": "./dist/vercel.js",
      "require": "./dist/vercel.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "llm",
    "tool-use",
    "langchain",
    "mcp",
    "vercel-ai-sdk",
    "compression",
    "tscg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tscg-project/tscg"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts src/langchain.ts src/mcp.ts src/vercel.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tscg/core": "^1.4.3"
  },
  "peerDependenciesMeta": {
    "@tscg/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@tscg/core": "^1.4.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
